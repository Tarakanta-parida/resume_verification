# Optional AI Model API Keys (App automatically falls back to local rule engine if not provided)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here

# Optional Database & Supabase Storage Configuration (Falls back to SQLite & local storage if omitted)
DATABASE_URL=postgresql://user:password@host:5432/dbname
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key
SUPABASE_BUCKET_NAME=ats-resumes
